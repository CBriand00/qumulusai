# ============================================================================
#  The One — Environment variables
#  Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# --- Public site ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (client-safe) -------------------------------------------------
# Project settings → API. The anon key is public and always RLS-restricted.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server ONLY — never expose to the browser) -------------------
# Bypasses RLS. Used by trusted server code and the seed script only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Seed script (development only) -----------------------------------------
SEED_ADMIN_EMAIL=admin@theone.example
SEED_ADMIN_PASSWORD=change-me-strong

# --- AI provider (decision-support only; modular) ---------------------------
# AI_PROVIDER=mock is the default and needs no key.
AI_PROVIDER=mock
# AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
# Optional: point at any OpenAI-compatible endpoint (default api.openai.com).
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Email provider (Resend-compatible; modular) ----------------------------
# EMAIL_PROVIDER=console is the default and needs no key.
EMAIL_PROVIDER=console
# EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="The One <no-reply@theone.example>"

# --- Stripe (architecture only — DO NOT enable payments yet) ----------------
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Google Calendar (integration-ready) ------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
